  "assemblies": {
    "Drive Assembly": {
      "components": ["1", "6", "7", "9"],
      "description": "Drive shaft rotates in 180° increments. Eccentric converts rotation to reciprocating motion via strap. Rod transfers motion to heddle."
    },
    "Pawl Clutch System": {
      "components": ["5", "2", "4", "60"],
      "description": "Pawl engages/disengages from shaft slots to couple the eccentric to the drive."
    },
    "Control Lever Mechanism": {
      "components": ["14", "12", "21", "23"],
      "description": "Two-armed control levers on bearing pins linked by articulated joint and bar."
    },
    "Stroke Member Assembly": {
      "components": ["31", "32", "33", "41", "37", "48"],
      "description": "Three-armed stroke member with overload protection levers and drive lever."
    },
    "Program Control": {
      "components": ["51", "53", "69"],
      "description": "Electromagnet controls pawl engagement per weave program signal."
    },
    "Monitoring System": {
      "components": ["73", "78", "83", "82", "85", "86", "88", "91"],
      "description": "Transmission linkage drives proximity switch via vane for closed-loop heddle position monitoring."
    }
